{
  "name": "@use-portal-co/portal-js",
  "version": "0.1.3",
  "description": "Realtime client SDK for Portal",
  "keywords": [
    "realtime",
    "websocket",
    "chat",
    "portal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useportal/portal-js.git"
  },
  "author": "Rodrigo Weilg",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "pnpm@10.7.1",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "partysocket": "^1.1.18"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
